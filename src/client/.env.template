# Client environment template. Keep values empty when committing.
# For selfhost, see .env.selfhost.template. For env var requests see:
# https://github.com/existence-master/Sentient/discussions/13

# Use any value other than "selfhost" for Supabase auth (e.g. leave unset or set to a placeholder).
# Set to "selfhost" only when self-hosting with token auth.
NEXT_PUBLIC_ENVIRONMENT=
SELF_HOST_AUTH_TOKEN= # Must match SELF_HOST_AUTH_SECRET on the server if using selfhost mode

# --- Supabase (required when not in selfhost mode) ---
# From your Supabase project: Settings > API. Client uses these for auth and API calls.
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your_supabase_anon_key>

# --- App URLs ---
APP_BASE_URL="http://localhost:3000"
NEXT_PUBLIC_APP_BASE_URL="http://localhost:3000"
NEXT_PUBLIC_APP_SERVER_URL="http://localhost:5000"
NEXT_PUBLIC_AUTH0_NAMESPACE="https://existence.sentient/auth0"

# URL for the landing page/dashboard for billing and account management
NEXT_PUBLIC_LANDING_PAGE_URL="http://localhost:3002"

# --- Analytics (Optional) ---
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# --- PWA Push Notifications (Optional) ---
# Generate VAPID keys using `npx web-push generate-vapid-keys`.
# Public key here must match the key derived from VAPID_PRIVATE_KEY on the server.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_ADMIN_EMAIL=mailto:your-email@example.com
