# src/server/.env.template
# For selfhost, see .env.selfhost.template and root src/.env.selfhost.template.

# --- Environment ---
# dev-local loads .env.local or .env from this directory. Use selfhost for Docker self-hosted mode.
ENVIRONMENT=dev-local

# --- Supabase (primary auth & database) ---
# From your Supabase project: Settings > API. Main app uses Supabase for auth and data.
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_SERVICE_KEY=<your_supabase_service_role_key>
SUPABASE_ANON_KEY=<your_supabase_anon_key>
SUPABASE_JWT_SECRET=<your_supabase_jwt_secret>

# --- Self-host & optional Auth0 (for selfhost/legacy) ---
SELF_HOST_AUTH_SECRET=<generate_a_strong_secret_for_self_hosting_if_using_that_mode>
# Optional: for selfhost permissions fallback
AUTH0_SCOPE="openid profile email offline_access read:chat write:chat read:profile write:profile manage:google_auth read:memory write:memory read:tasks write:tasks read:notifications write:notifications read:config write:config admin:user_metadata"
AUTH0_AUDIENCE=<your-dev-api-identifier>

# --- Server ---
APP_SERVER_PORT=5000

# --- Database (workers & Memory MCP) ---
# Main app DB is Supabase. Mongo and Postgres are used by Celery workers and Memory MCP.
# IMPORTANT: If your password contains special characters like '@', ':', '/', or '+', you MUST URL-encode them.
MONGO_URI="mongodb+srv://<user>:<url_encoded_password>@<cluster>.mongodb.net/"
MONGO_DB_NAME=sentient_dev_db

# PostgreSQL (Memory MCP)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=test
POSTGRES_PASSWORD=test
POSTGRES_DB=mcp_memory

# --- Task Queue (Celery) ---
# IMPORTANT: If your Redis password contains special characters, it must be URL-encoded.
REDIS_PASSWORD=<your_redis_password>
CELERY_BROKER_URL="redis://:<url_encoded_password>@<host>:<port>/0"
CELERY_RESULT_BACKEND="redis://:<url_encoded_password>@<host>:<port>/0"

# --- Vector DB (Chroma) ---
CHROMA_HOST=localhost
CHROMA_PORT=8002

# --- LLM & Embedding Configuration ---
# You can point this to any OpenAI API compatible service (OpenAI, Groq, Together, vLLM, Ollama).
OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=<your_openai_api_key>
OPENAI_MODEL_NAME=gpt-4o-mini
GEMINI_API_KEY=<your-gemini-api-key>
EMBEDDING_MODEL_NAME=models/gemini-embedding-001

# --- PWA Push Notifications ---
# These MUST match the VAPID keys in the client's .env file.
VAPID_PRIVATE_KEY=<your_vapid_private_key>
VAPID_ADMIN_EMAIL=mailto:your-email@example.com

# --- Voice Configuration ---
STT_PROVIDER=DEEPGRAM       # Can be FASTER_WHISPER, ELEVENLABS, or DEEPGRAM
TTS_PROVIDER=ELEVENLABS    # Can be ORPHEUS, ELEVENLABS, or SMALLEST_AI
ELEVENLABS_API_KEY=<your_elevenlabs_api_key_if_using>
DEEPGRAM_API_KEY=<your_deepgram_api_key_if_using>
SMALLEST_AI_API_KEY=<your_smallest_ai_api_key>
FASTER_WHISPER_MODEL_SIZE=base
FASTER_WHISPER_DEVICE=cuda
FASTER_WHISPER_COMPUTE_TYPE=float16
ORPHEUS_MODEL_PATH="src/server/main/voice/models/orpheus-3b-0.1-ft-q4_k_m.gguf"
ORPHEUS_N_GPU_LAYERS=0
HF_TOKEN=<your_huggingface_token>

# --- File Management ---
FILE_MANAGEMENT_TEMP_DIR=/tmp/sentient_files
FILE_CLEANUP_INTERVAL_SECONDS=3600
FILE_MAX_AGE_SECONDS=86400

# --- 3rd Party APIs ---
POSTHOG_KEY=<your_posthog_project_api_key>
POSTHOG_HOST=<your_posthog_host>
NEWS_API_KEY=<your-news-api-key>
GOOGLE_CLIENT_ID=<your-google-oauth-client-id>
GOOGLE_PROJECT_ID=<your-google-cloud-project-id>
GOOGLE_CLIENT_SECRET=<your-google-oauth-client-secret>
GOOGLE_API_KEY=<your-google-cloud-api-key>
GOOGLE_CSE_ID=<your-google-custom-search-engine-id>
UNSPLASH_ACCESS_KEY=<your-unsplash-access-key>
SLACK_CLIENT_ID=<your-slack-oauth-app-client-id>
SLACK_CLIENT_SECRET=<your-slack-oauth-app-client-secret>
NOTION_CLIENT_ID=<your-notion-oauth-app-client-id>
NOTION_CLIENT_SECRET=<your-notion-oauth-app-secret>
DISCORD_BOT_TOKEN=<your-discord-bot-token>
DISCORD_CLIENT_ID=<your-discord-oauth-app-client-id>
DISCORD_CLIENT_SECRET=<your-discord-oauth-app-client-secret>
TRELLO_CLIENT_ID=<your-trello-api-key>
GITHUB_CLIENT_ID=<your-github-oauth-app-client-id>
GITHUB_CLIENT_SECRET=<your-github-oauth-app-client-secret>
ACCUWEATHER_API_KEY=<your-accuweather-api-key>
TODOIST_CLIENT_ID=<your-todoist-oauth-client-id>
TODOIST_CLIENT_SECRET=<your-todoist-oauth-client-secret>

# --- Composio Configuration ---
COMPOSIO_API_KEY=<your_composio_api_key>
GMAIL_AUTH_CONFIG_ID=<your_composio_gmail_auth_config_id>
GDRIVE_AUTH_CONFIG_ID=<your_composio_gdrive_auth_config_id>
GCALENDAR_AUTH_CONFIG_ID=<your_composio_gcalendar_auth_config_id>
GDOCS_AUTH_CONFIG_ID=<your_composio_gdocs_auth_config_id>
GTASKS_AUTH_CONFIG_ID=<your_composio_gtasks_auth_config_id>
GSHEETS_AUTH_CONFIG_ID=<your_composio_gsheets_auth_config_id>

# --- Encryption ---
AES_SECRET_KEY=<generate_a_64_char_hex_string_for_dev>
AES_IV=<generate_a_32_char_hex_string_for_dev>

# --- Google Sheets Integration (for adding contacts) ---
GOOGLE_SHEET_ID=<your_google_sheet_id>
GOOGLE_CLIENT_EMAIL=<your_google_service_account_email>
GOOGLE_PRIVATE_KEY="<your_google_service_account_private_key_with_newlines_escaped>"

# --- WhatsApp API (WAHA) ---
WAHA_URL="http://localhost:8000"
WHATSAPP_DEFAULT_ENGINE=GOWS
WAHA_API_KEY="admin"
WAHA_DASHBOARD_USERNAME=admin
WAHA_DASHBOARD_PASSWORD=admin

